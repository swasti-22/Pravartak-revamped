# Pravartak V2 Environment Variables Template

# Frontend Supabase Config (Loaded in Vite)
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Backend AI Integration (Loaded in FastAPI)
GEMINI_API_KEY=your-google-gemini-api-key

# Backend Database Config (Loaded in FastAPI)
# (Same as VITE_SUPABASE_URL, but loaded directly in python backend)
SUPABASE_URL=https://your-supabase-project-id.supabase.co
# Service role key or anon key to authenticate python requests
SUPABASE_KEY=your-supabase-service-role-or-anon-key
